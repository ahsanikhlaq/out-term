{% doc %}
  @prompt
    create two buttons side by side in a transparent background with borders.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-button-pair-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_spacing }}px;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    padding: {{ block.settings.container_padding }}px;
    background: transparent;
  }

  .ai-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background: transparent;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    cursor: pointer;
    transition: all0.3s ease;
    min-width: {{ block.settings.min_button_width }}px;
  }

  .ai-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.hover_background_color }};
    border-color: {{ block.settings.hover_border_color }};color: {{ block.settings.hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-button-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.text_color }};
    outline-offset: 2px;
  }

  @media screen and (max-width: 749px) {
    .ai-button-pair-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap: {{ block.settings.mobile_spacing }}px;
    }

    .ai-button-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'column' %}
        width: 100%;
      {% endif %}
      font-size: {{ block.settings.mobile_font_size }}px;padding: {{ block.settings.mobile_padding_vertical }}px {{ block.settings.mobile_padding_horizontal }}px;
    }
  }
{% endstyle %}

<div class="ai-button-pair-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.button_1_text != blank %}
    <a
      href="{{ block.settings.button_1_link }}"
      class="ai-button-{{ ai_gen_id }}"
      {% if block.settings.button_1_link == blank %}role="button" tabindex="0"{% endif %}
    >
      {{ block.settings.button_1_text }}
    </a>
  {% endif %}

  {% if block.settings.button_2_text != blank %}
    <a
      href="{{ block.settings.button_2_link }}"
      class="ai-button-{{ ai_gen_id }}"
      {% if block.settings.button_2_link == blank %}role="button" tabindex="0"{% endif %}
    >
      {{ block.settings.button_2_text }}
    </a>
  {% endif %}
</div>

