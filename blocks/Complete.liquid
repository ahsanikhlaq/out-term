<style>
  /* ------------------------------upsell------------------- */
.cs_complete_main .cs_pro_class_product_main{
    display: grid;
    gap: 20px;
    width: 100%;
    grid-template-columns: 15% auto;
   
}
.cs_complete_main .cs_pro_class_product_main .cs_coll_tab_cart_content {
    padding: 0;
        display: flex;
    flex-direction: row-reverse;
        justify-content: space-between;
    align-items: center;
}   
.cs_complete_main .cs_pro_class_product_main .dps-image img {
    max-width: 90px;
    object-fit: cover;
    max-height: 90px;
    min-height: 90px;
}
.cs_complete_main .cs_coll_tab_title_varint {
    flex-direction: column;
    margin: 0;
        gap: 4px;

}
.cs_complete_main .product-card {
        background: transparent;
    position: relative;
}
.cs_complete_main .cs_pro_com_heading{
    margin: 0;
    font-family: FONTSPRING DEMO - Gibson Book;
font-weight: 300;
font-style: Regular;
font-size: 25px;
leading-trim: NONE;
line-height: 28px;
letter-spacing: 0px;
vertical-align: middle;
text-transform: uppercase;
padding-bottom: 10px;
border-bottom: 1px solid #0C0B0B
}
.cs_complete_main .cs_coll_tab_cart_buy_button{
        width: 77px;
    height: 37px;
}
.cs_complete_main .cs_por_varint-color_size_main{
    display: flex;
    gap: 14px;
    margin-top: 7px;
}
.cs_complete_main .cs_coll_tab_pro_size_varint{
    margin: 0;
}
.cs_coll_tab_cart_buy_button_des{
    display: flex;
}
.cs_coll_tab_cart_buy_button_mbl{
    display: none;
}
.cs_complete_main .product-card{
 border-bottom: 1px solid #0000004D;
    padding: 10px 0;
  }
  {% comment %} ---------------- {% endcomment %}
   .size-dropdown {
  padding: 6px 2px;
  border: 1px solid #ccc;
  border-radius: 4px;
  font-size: 14px;
  cursor: pointer;
  width: auto;
  min-width: 120px;
}

.size-dropdown option:disabled {
  color: #aaa;
}
.color-dropdown-wrapper {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  padding: 6px 10px;
  background: #fff;
  cursor: pointer;
}

.color-dropdown-dot {
  width: 18px;
  height: 18px;
  border-radius: 3px;
  display: inline-block;
  flex-shrink: 0;
  border: 1px solid rgba(0, 0, 0, 0.1);
  background: #cccccc;
}

.color-dropdown {
  border: none;
  outline: none;
  background: transparent;
  font-size: 14px;
  color: #111;
  cursor: pointer;
  appearance: auto;
}
  @media (max-width: 768px) {
    .cs_complete_main .cs_pro_com_heading {
    font-size: 22px;
    line-height: 24px;
    padding: 16px 0 7px 0;
  }
  .cs_complete_main .cs_pro_class_product_main .cs_coll_tab_cart_content {
    flex-direction: row-reverse;
    justify-content: left;
  }
  .size-dropdown {
    border-radius: 2px;
    min-width: 80px !important;
    max-width: 80px !important;
    width: 80px !important;
}
.cs_coll_tab_cart_buy_button_des{
    display: none;
}
.cs_coll_tab_cart_buy_button_mbl{
    display: flex;
    width: 100% !important;
        margin-top: 10px;
}
.cs_complete_main .cs_pro_class_product_main {
    grid-template-columns: 22% auto;
}
}
</style>
<div class="cs_complete_main">
  {% if block.settings.heading !=blank %}
    <h4 class="cs_pro_com_heading">{{ block.settings.heading }}</h4>
  {% endif %}
    <div>
       <div class="swiper-wrapper">
  
      {% assign product = all_products[block.settings.cs_product] %}
      
      {% if product != blank %}
        <div class="swiper-slide product-card">
          {% render 'custom-product-sec-cart', product: product, section_id: section.id %}
        </div>
      {% endif %}
    
</div>
    </div>
</div>
{% schema %}
{
  "name": "parent_block",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "Heading"
    },
     {
        "type": "product",
        "id": "cs_product",
        "label": "Select Product"
        },
  ],
  "presets": [
    {
      "name": "parent_block",
},
]
}
{% endschema %}


