      {% comment %} ---tab-script {% endcomment %}

{% comment %} ------------------add-to-cart----------------- {% endcomment %}
<script>
document.addEventListener('DOMContentLoaded', function () {

  // 1. Helper: Sync size + color
  function syncHiddenInputs(card) {
    const sizeInput = card.querySelector('.size-badge_input:checked');
    const colorInput = card.querySelector('.color-badge_input:checked');
    const hiddenSize = card.querySelector('.cs_coll_tab_slect_size');
    const hiddenColor = card.querySelector('.cs_coll_tab_slect_color');
    if (hiddenSize) hiddenSize.value = sizeInput ? sizeInput.value : '';
    if (hiddenColor) hiddenColor.value = colorInput ? colorInput.getAttribute('variant-id') : '';
  }

  document.querySelectorAll('.swiper-slide.product-card').forEach(card => syncHiddenInputs(card));

  // 2. Selection changes
  document.querySelectorAll('.size-badge_input, .color-badge_input').forEach(input => {
    input.addEventListener('change', function () {
      const card = this.closest('.swiper-slide.product-card');
      if (card) {
        if (this.classList.contains('color-badge_input')) {
          const colorNameSpan = card.querySelector('.selected-color-name');
          if (colorNameSpan) colorNameSpan.textContent = this.value;
        }
        syncHiddenInputs(card);
      }
    });
  });

  // 3. Correct section ID nikalo page se
  function getCartSectionId() {
    const cartItems = document.querySelector('cart-items-component[data-section-id]');
    if (cartItems) return cartItems.getAttribute('data-section-id');
    return 'sections--26355253805372__header_section'; // fallback
  }

  // 4. Add to Cart Logic
  document.querySelectorAll('.cs_coll_tab_cart_buy_button').forEach(button => {
    button.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopImmediatePropagation();

      const btn = this;
      const card = btn.closest('.swiper-slide.product-card');
      if (!card) return;

      const variantId = card.querySelector('.cs_coll_tab_slect_size')?.value ||
                        card.querySelector('.cs_coll_tab_slect_color')?.value;

      if (!variantId) {
        alert('Please select options first!');
        return;
      }

      btn.disabled = true;
      const originalHTML = btn.innerHTML;
      btn.innerHTML = 'Adding...';

      const sectionId = getCartSectionId();

      const formData = {
        id: variantId,
        quantity: 1,
        sections: sectionId
      };

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      })
      .then(response => response.json())
      .then(parsedState => {
        if (parsedState.status === 422) throw new Error(parsedState.description);

        const cartDrawer = document.querySelector('cart-drawer-component');
        const sectionHTML = parsedState.sections?.[sectionId];

        if (cartDrawer && sectionHTML) {
          const parsed = new DOMParser().parseFromString(sectionHTML, 'text/html');

          // cart-items-component update karo
          const newCartItems = parsed.querySelector('cart-items-component');
          const currentCartItems = cartDrawer.querySelector('cart-items-component');

          if (currentCartItems && newCartItems) {
            currentCartItems.innerHTML = newCartItems.innerHTML;
          } else {
            const newInner = parsed.querySelector('[data-hydration-key="cart-drawer-inner"]') ||
                             parsed.querySelector('.cart-drawer__inner');
            const currentInner = cartDrawer.querySelector('[data-hydration-key="cart-drawer-inner"]') ||
                                 cartDrawer.querySelector('.cart-drawer__inner');
            if (currentInner && newInner) {
              currentInner.innerHTML = newInner.innerHTML;
            }
          }

          // Empty class hata do
          const dialog = cartDrawer.querySelector('dialog');
          if (dialog) {
            dialog.classList.remove('cart-drawer--empty');
          }
        }

        // Cart bubble update
        const cartBubbleCount = document.querySelector('[ref="cartBubbleCount"], .cart-bubble__text-count');
        if (cartBubbleCount && parsedState.items_count !== undefined) {
          cartBubbleCount.textContent = parsedState.items_count;
          cartBubbleCount.classList.remove('hidden');
          const bubble = document.querySelector('[ref="cartBubble"], .cart-bubble');
          if (bubble) bubble.classList.remove('visually-hidden');
        }

        // 5. Drawer open karo
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const drawerEl = document.querySelector('cart-drawer-component');
            if (drawerEl) {

              // Pehle theme ka trigger button try karo
              const cartTriggerBtn = drawerEl.querySelector('[data-testid="cart-drawer-trigger"], [on\\:click="/open"]');
              if (cartTriggerBtn) {
                cartTriggerBtn.click();
              } else {
                // Fallback: dialog force open
                const dialog = drawerEl.querySelector('dialog[ref="dialog"]');
                if (dialog) {
                  dialog.setAttribute('open', '');
                  dialog.style.display = 'flex';
                  dialog.style.visibility = 'visible';
                  dialog.style.opacity = '1';
                  dialog.style.transform = 'translateX(0)';
                }
                document.body.classList.add('overflow-hidden');
              }
            }

            document.dispatchEvent(new CustomEvent('cart:updated', {
              detail: { cart: parsedState }
            }));
          });
        });

      })
      .catch(error => {
        console.error('Cart Error:', error);
        alert(error.message || 'Kuch masla hua, dobara try karo.');
      })
      .finally(() => {
        btn.disabled = false;
        btn.innerHTML = originalHTML;
      });

    });
  });

});
</script>















<script>
  document.addEventListener('DOMContentLoaded', function() {
  const zoomButtons = document.querySelectorAll('.cs_coll_cart_zoom_img');

  zoomButtons.forEach(button => {
    button.addEventListener('click', function(e) {
      // Button ke sabse kareeb jo product card hai uske andar wali image dhoondein
      const productCard = this.closest('.product-card');
      const imageWrapper = productCard.querySelector('.dps-image');
      const img = imageWrapper.querySelector('img');

      // Toggle Zoom class
      imageWrapper.classList.toggle('is-zoomed');

      // Optional: Mouse move par image follow kare (Sirf agar zoomed ho)
      imageWrapper.addEventListener('mousemove', function(e) {
        if (this.classList.contains('is-zoomed')) {
          const rect = this.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width) * 100;
          const y = ((e.clientY - rect.top) / rect.height) * 100;
          img.style.transformOrigin = `${x}% ${y}%`;
        }
      });

      // Reset origin on mouse leave
      imageWrapper.addEventListener('mouseleave', function() {
        img.style.transformOrigin = 'center center';
      });
    });
  });
});
</script>
  </body>
  <script>
  (function () {
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  function observeItems() {
    document.querySelectorAll('.animate-item').forEach((el) => {
      observer.observe(el);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeItems);
  } else {
    observeItems();
  }
})();
</script>
</html>
