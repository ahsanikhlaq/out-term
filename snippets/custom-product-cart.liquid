{% comment %} Ab yahan sirf 'product' variable use karo, koi loop nahi {% endcomment %}

<div class="cs_coll_cart_zoom_img">{% render 'image-zoom-svg' %}</div>

<a class="dps-image" href="{{ product.url }}">
  <img
    src="{{ product.featured_image | img_url: '480x480' }}"
    alt="{{ product.title }}"
  >
</a>

<div class="cs_coll_tab_cart_content">
  <button 
  class="cs_coll_tab_cart_buy_button"
  data-product-handle="{{ product.handle }}"
  {% unless product.available %} disabled {% endunless %}
>
  <input class="cs_coll_tab_slect_size" type="hidden" name="slected-size" value="">
  <input class="cs_coll_tab_slect_color" type="hidden" name="slected-color" value="">
  {% render 'buy-button-bag-svg' %}
  <span class="btn-label">
    {% if product.available %}add to bag{% else %}out of stock{% endif %}
  </span>
</button>

  <div class="cs_coll_tab_title_varint">
    <h4 class="dps-title">{{ product.title }}</h4>

   <span class="cs_coll_tab_pro_price">{{ product.price | money }}</span>
  </div>
 <div class="cs_coll_tab_pro_size_varint">
  {% assign size_option_index = nil %}
  {% assign first_available_found = false %}

  {% for option in product.options %}
    {% if option == 'Size' %}
      {% assign size_option_index = forloop.index0 %}
    {% endif %}
  {% endfor %}

  {% if size_option_index != nil %}
    {% for variant in product.variants %}
      
      {% assign is_checked = false %}
      {% if variant.available and first_available_found == false %}
        {% assign is_checked = true %}
        {% assign first_available_found = true %}
      {% endif %}

      <span class="size-badge {% unless variant.available %}out-of-stock{% endunless %}">
        
        <input 
  class="size-badge_input" 
  type="radio"
  name="variant-size-{{ product.handle }}-{{ section_id }}"
  value="{{ variant.id }}"
  data-available="{{ variant.available }}"
  {% if is_checked %}checked{% endif %}
  {% unless variant.available %}disabled{% endunless %}
>

        <label>
          {{ variant.options[size_option_index] }}
        </label>

      </span>

    {% endfor %}
  {% endif %}
</div>
  

  <div class="cs_coll_tab_pro_color_varint">
    {% assign color_option = nil %}
    {% for option in product.options_with_values %}
      {% if option.name == 'Color' %}
        {% assign color_option = option %}
      {% endif %}
    {% endfor %}

    {% if color_option != nil %}
      <div class="color-swatches">
        {% for option_value in color_option.values %}

          {% assign swatch_value = '#cccccc' %}
          {% if option_value.swatch.color %}
            {% assign swatch_value = 'rgb(' | append: option_value.swatch.color.rgb | append: ')' %}
          {% elsif option_value.swatch.image %}
            {% assign swatch_img = option_value.swatch.image | image_url: width: 80 %}
            {% assign swatch_value = 'url(' | append: swatch_img | append: ')' %}
          {% endif %}

          <label class="color-badge">
            {% comment %} Color Swatch loop ke andar {% endcomment %}
<input class="color-badge_input" type="radio"
  name="variant-color-{{ product.handle }}-{{ section_id }}"
  value="{{ option_value.name }}"
  {% comment %} Niche wali line add karein: hum variant ki image fetch kar rahe hain {% endcomment %}
  data-variant-img="{{ option_value.variant.featured_media | img_url: '480x480' }}"
  {% if forloop.first %}checked{% endif %}>
            <span class="color-circle" style="background: {{ swatch_value }};"></span>
          </label>

        {% endfor %}
      </div>
      <span class="selected-color-name">
        {{ color_option.values.first.name }}
      </span>
    {% endif %}
  </div>
</div>
<script>
(function() {
  var cards = document.querySelectorAll('.product-card');
  
  cards.forEach(function(card) {
    card.addEventListener('change', function(e) {
      var input = e.target;
      
      if (!input.classList.contains('size-badge_input') && 
          !input.classList.contains('color-badge_input')) return;

      var btn = card.querySelector('.cs_coll_tab_cart_buy_button');
      var btnText = btn.querySelector('.btn-label');
      
      var selectedVariantInput = card.querySelector('.size-badge_input:checked');
      
      if (!selectedVariantInput) return;

      // Debug line - baad mein hata dena
      console.log('data-available value:', selectedVariantInput.dataset.available);

      var isAvailable = selectedVariantInput.dataset.available === 'true';

      if (isAvailable) {
        btn.disabled = false;
        if (btnText) btnText.textContent = 'add to bag';
      } else {
        btn.disabled = true;
        if (btnText) btnText.textContent = 'out of stock';
      }
    });
  });
})();
</script>
<script>
  (function() {
  var cards = document.querySelectorAll('.product-card'); // Ensure your wrapper has this class
  
  cards.forEach(function(card) {
    card.addEventListener('change', function(e) {
      var input = e.target;
      
      // 1. Agar color change hua hai
      if (input.classList.contains('color-badge_input')) {
        var newImgUrl = input.dataset.variantImg;
        var productImage = card.querySelector('.dps-image img');
        
        if (newImgUrl && productImage) {
          productImage.src = newImgUrl;
        }

        // Color name update karne ke liye (Optional)
        var colorNameSpan = card.querySelector('.selected-color-name');
        if (colorNameSpan) colorNameSpan.textContent = input.value;
      }

      // 2. Aapka purana Stock Availability logic
      if (input.classList.contains('size-badge_input')) {
        var btn = card.querySelector('.cs_coll_tab_cart_buy_button');
        var btnText = btn.querySelector('.btn-label');
        var isAvailable = input.dataset.available === 'true';

        if (isAvailable) {
          btn.disabled = false;
          if (btnText) btnText.textContent = 'add to bag';
        } else {
          btn.disabled = true;
          if (btnText) btnText.textContent = 'out of stock';
        }
      }
    });
  });
})();
</script>