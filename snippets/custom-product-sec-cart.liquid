{% style %}
  
{% endstyle %}

{% comment %} Ab yahan sirf 'product' variable use karo, koi loop nahi {% endcomment %}
<div class="cs_pro_class_product_main">
  <a class="dps-image" href="{{ product.url }}">
    <img
      src="{{ product.featured_image | img_url: '480x480' }}"
      alt="{{ product.title }}"
    >
  </a>

  <div class="cs_coll_tab_cart_content">
    <button
      class="cs_coll_tab_cart_buy_button cs_coll_tab_cart_buy_button_des"
      data-product-handle="{{ product.handle }}"
      {% unless product.available %} disabled {% endunless %}
    >
      <input class="cs_coll_tab_slect_size" type="hidden" name="slected-size" value="">
      <input class="cs_coll_tab_slect_color" type="hidden" name="slected-color" value="">
      <span class="btn-label">
        {% if product.available %}add{% else %}out of stock{% endif %}
      </span>
    </button>

    <div class="com_pro_content">
      <div class="cs_coll_tab_title_varint">
        <h4 class="dps-title">{{ product.title }}</h4>
        <span class="cs_coll_tab_pro_price">{{ product.price | money }}</span>
      </div>

      <div class="cs_por_varint-color_size_main">

        
        <div class="cs_coll_tab_pro_size_varint">
          {% assign size_option_index = nil %}
          {% assign first_available_variant_id = nil %}

          {% for option in product.options %}
            {% if option == 'Size' %}
              {% assign size_option_index = forloop.index0 %}
            {% endif %}
          {% endfor %}

          {% if size_option_index != nil %}
            <select
              class="size-dropdown"
              name="variant-size-{{ product.handle }}-{{ section_id }}"
              id="size-select-{{ product.handle }}-{{ section_id }}"
            >
              {% for variant in product.variants %}
                {% assign is_selected = false %}
                {% if variant.available and first_available_variant_id == nil %}
                  {% assign first_available_variant_id = variant.id %}
                  {% assign is_selected = true %}
                {% endif %}

                <option
                  class="size-badge_input"
                  value="{{ variant.id }}"
                  data-available="{{ variant.available }}"
                  {% if is_selected %}selected{% endif %}
                  {% unless variant.available %}disabled{% endunless %}
                >
                  {{ variant.options[size_option_index] }}{% unless variant.available %} — Out of Stock{% endunless %}
                </option>
              {% endfor %}
            </select>
          {% endif %}
        </div>

        
        <div class="cs_coll_tab_pro_color_varint">
          {% assign color_option = nil %}
          {% for option in product.options_with_values %}
            {% if option.name == 'Color' %}
              {% assign color_option = option %}
            {% endif %}
          {% endfor %}

          {% if color_option != nil %}
            <div class="color-dropdown-wrapper">
              <span
                class="color-dropdown-dot"
                id="swatch-dot-{{ product.handle }}-{{ section_id }}"
              ></span>

              <select
                class="color-dropdown"
                name="variant-color-{{ product.handle }}-{{ section_id }}"
                id="color-select-{{ product.handle }}-{{ section_id }}"
              >
                {% for option_value in color_option.values %}

                  {% comment %} Swatch color/image set karo {% endcomment %}
                  {% assign swatch_value = '#cccccc' %}
                  {% if option_value.swatch.color %}
                    {% assign swatch_value = 'rgb(' | append: option_value.swatch.color.rgb | append: ')' %}
                  {% elsif option_value.swatch.image %}
                    {% assign swatch_img = option_value.swatch.image | image_url: width: 80 %}
                    {% assign swatch_value = 'url(' | append: swatch_img | append: ')' %}
                  {% endif %}

                  {% comment %} Is color ka pehla AVAILABLE variant ID dhundo {% endcomment %}
                  {% assign matched_variant_id = nil %}
                  {% for variant in product.variants %}
                    {% if variant.available and matched_variant_id == nil %}
                      {% for opt in variant.options %}
                        {% if opt == option_value.name %}
                          {% assign matched_variant_id = variant.id %}
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                  {% endfor %}

                  {% comment %} Agar koi available nahi toh pehla variant le lo {% endcomment %}
                  {% if matched_variant_id == nil %}
                    {% for variant in product.variants %}
                      {% if matched_variant_id == nil %}
                        {% for opt in variant.options %}
                          {% if opt == option_value.name %}
                            {% assign matched_variant_id = variant.id %}
                          {% endif %}
                        {% endfor %}
                      {% endif %}
                    {% endfor %}
                  {% endif %}

                  <option
                    value="{{ option_value.name }}"
                    data-variant-id="{{ matched_variant_id }}"
                    data-swatch="{{ swatch_value }}"
                    data-variant-img="{{ option_value.variant.featured_media | img_url: '480x480' }}"
                    {% if forloop.first %}selected{% endif %}
                  >
                    {{ option_value.name }}
                  </option>

                {% endfor %}
              </select>
            </div>
          {% endif %}
        </div>

      </div>
    </div>
  </div>
</div>
<button
      class="cs_coll_tab_cart_buy_button cs_coll_tab_cart_buy_button_mbl"
      data-product-handle="{{ product.handle }}"
      {% unless product.available %} disabled {% endunless %}
    >
      <input class="cs_coll_tab_slect_size" type="hidden" name="slected-size" value="">
      <input class="cs_coll_tab_slect_color" type="hidden" name="slected-color" value="">
      <span class="btn-label">
        {% if product.available %}add{% else %}out of stock{% endif %}
      </span>
    </button>
<script>
(function() {

  // ===================== SWATCH DOT INIT =====================
  // Page load par pehle selected color ka swatch dot set karo
  document.querySelectorAll('.color-dropdown').forEach(function(select) {
    var dotId = select.id.replace('color-select-', 'swatch-dot-');
    var dot = document.getElementById(dotId);
    if (dot) {
      var swatch = select.options[select.selectedIndex].getAttribute('data-swatch');
      if (swatch) dot.style.background = swatch;
    }
  });

  // ===================== COLOR CHANGE =====================
  document.querySelectorAll('.color-dropdown').forEach(function(select) {
    select.addEventListener('change', function() {
      var selectedOption = this.options[this.selectedIndex];

      // 1. Swatch dot update karo
      var dotId = this.id.replace('color-select-', 'swatch-dot-');
      var dot = document.getElementById(dotId);
      if (dot) {
        var swatch = selectedOption.getAttribute('data-swatch');
        if (swatch) dot.style.background = swatch;
      }

      // 2. Product image update karo
      var wrapper = this.closest('.cs_pro_class_product_main');
      if (wrapper) {
        var newImgUrl = selectedOption.getAttribute('data-variant-img');
        var productImage = wrapper.querySelector('.dps-image img');
        if (newImgUrl && productImage) {
          productImage.src = newImgUrl;
        }
      }

      // 3. Color variant ID hidden input mein save karo
      if (wrapper) {
        var colorInput = wrapper.querySelector('.cs_coll_tab_slect_color');
        if (colorInput) {
          colorInput.value = selectedOption.getAttribute('data-variant-id') || '';
        }
      }
    });
  });

  // ===================== SIZE CHANGE =====================
  document.querySelectorAll('.size-dropdown').forEach(function(select) {
    select.addEventListener('change', function() {
      var selectedOption = this.options[this.selectedIndex];
      var wrapper = this.closest('.cs_pro_class_product_main');
      if (!wrapper) return;

      var btn = wrapper.querySelector('.cs_coll_tab_cart_buy_button');
      var btnText = btn ? btn.querySelector('.btn-label') : null;
      var isAvailable = selectedOption.getAttribute('data-available') === 'true';

      // Button state update karo
      if (btn) btn.disabled = !isAvailable;
      if (btnText) btnText.textContent = isAvailable ? 'add' : 'out of stock';

      // Size variant ID hidden input mein save karo
      var sizeInput = wrapper.querySelector('.cs_coll_tab_slect_size');
      if (sizeInput) {
        sizeInput.value = isAvailable ? selectedOption.value : '';
      }
    });
  });

})();
</script>