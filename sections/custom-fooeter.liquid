<script>
  function trimTitle() {
    const titles = document.querySelectorAll('.ra-product-title');
    if (window.innerWidth <= 768) { // mobile
      titles.forEach(title => {
        const words = title.textContent.split(' ');
        title.textContent = words.slice(0, 3).join(' ');
      });
    }
  }

  window.addEventListener('resize', trimTitle);
  window.addEventListener('DOMContentLoaded', trimTitle);
</script>

