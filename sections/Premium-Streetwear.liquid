<section class="awards-section">
    <div class="page-width">
  <div class="awards-content">
    <h2 class="awards-heading animate-item">{{ section.settings.heading }}</h2>

    <div class="awards-grid animate-item">
      {% for block in section.blocks %}
        <div class="award-card animate-item" id="award-{{ forloop.index }}">
          {% if block.settings.icon %}
            <img src="{{ block.settings.icon | image_url }}" alt="">
          {% endif %}
          <div>
          <div class="award-title">{{ block.settings.title }}</div>
          <div class="award-text">{{ block.settings.text }}</div>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
  </div>
</section>

<style>
.awards-section {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
     background-color: {{ section.settings.bg_color }};
  
  }
.awards-heading {
    font-family: FONTSPRING DEMO - Gibson Book;
    font-weight: 300;
    font-style: Regular;
    font-size: 60px;
    leading-trim: NONE;
    line-height: 100%;
    letter-spacing: 0%;
    text-align: center;
    text-transform: uppercase;
    color: #221919;
    margin:0;
    padding-bottom: 60px;
}

.awards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
      max-width: 1170px;
    margin: 0 auto;
}

.award-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1 0 0;
  gap:20px;
border-right: 1px solid #221919;
}
.awards-grid .award-card:last-child {
 border-right: none;
}

.award-card img {
  width: 80px;
height: 80px;
object-fit:cover;
}

.award-title {
    font-family: Montserrat;
    font-weight: 400;
    font-style: Regular;
    font-size: 19px;
    leading-trim: NONE;
    line-height: 100%;
    letter-spacing: 0%;
    text-align: center;
    text-transform: uppercase;
    color: #221919;
    margin:0px;
}

.award-text p{
  font-family: Montserrat;
    font-weight: 400;
    font-style: Regular;
    font-size: 15px;
    leading-trim: NONE;
    line-height: 20px;
    letter-spacing: 0;
    text-align: center;
    color: #221919B2;
  margin:0px;
  padding-top: 14px;
}
.award-text p strong{
    font-weight: 600;
}
#award-1 .award-text {
  max-width:300px;
}
#award-2 .award-text {
  max-width:240px;
}
#award-3 .award-text {
  max-width:280px;
}


/* Mobile */
@media(max-width: 767px){
  .awards-section {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  .awards-grid {
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .awards-heading {
        font-size: 40px;
    padding-bottom: 25px;
  }
  .award-card {
      border: none;
      gap: 12px;
 }

 #award-2 .award-text {
    max-width: 245px;
}
#award-1 .award-text {
    max-width: 244px;
}
.award-card img {
    margin: 0 0 4px;
}
}
</style>

{% schema %}
{
  "name": "Premium Streetwear",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fallback Background Color",
      "default": "#0f2f36"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "recognition",
      "name": "Recognition Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Made in Canada"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Streetwear",
      "blocks": [
        { "type": "recognition" },
        { "type": "recognition" },
        { "type": "recognition" }
      ]
    }
  ]
}
{% endschema %}