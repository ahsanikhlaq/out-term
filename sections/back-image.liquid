<style>
  .section-{{ section.id }}{
      background-color: {{ section.settings.background_color }};
      padding-top: {{  section.settings.padding_top_desktop }}px ;
      padding-bottom: {{  section.settings.padding_bottom_desktop }}px ;
  }
  .cs_refined_back_des_img{
    display: block;
    object-fit: cover;
    width: 100%;
    height: auto;
  }
  .cs_refined_back_mbl_img{
    display: none;
    object-fit: cover;
    width: 100%;
    height: auto;
  }
  .cs_Refined_back_img_main{
    position: relative;
  }
  .cs_refined_back_content{
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-item: center;
  }
  .cs_refined_back_title{
    margin: 0;
    font-family: FONTSPRING DEMO - Gibson Book;
    font-weight: 300;
    font-style: Regular;
    font-size: 60px;
    leading-trim: NONE;
    line-height: 100%;
    letter-spacing: 0%;
    text-align: center;
    text-transform: uppercase;
    color: #FFFFFF;
  }
  .cs_refined_button{
    font-family: Montserrat;
font-weight: 500;
font-style: Medium;
font-size: 15px;
leading-trim: NONE;
line-height: 100%;
letter-spacing: 0%;
text-align: center;
text-transform: uppercase;
color: #221919;
padding: 20px 45px;
width: fit-content;
margin: 11px auto 0 auto;
display: flex;
align-itme: center;
justify-content: center;
background: #FFFFFF;

  }
    @media (max-width: 768px) {
      .section-{{ section.id }}{
          padding-top: {{  section.settings.padding_top_mobile }}px ;
          padding-bottom: {{  section.settings.padding_bottom_mobile }}px ;
      }
      .cs_refined_back_des_img{
    display: none;
  }
  .cs_refined_back_mbl_img{
    display: block;
  }
  .cs_refined_back_title{
    font-size: 40px;
  }
  .cs_refined_button{
    padding: 13px 32px;
    margin: 11px auto 0 auto;
  }
    }
</style>
<div class="section-{{ section.id }}">
    <div class="cs_Refined_back_img_main">
    <div class="cs_refined_back_img">
    <img class="cs_refined_back_des_img" src="{{ section.settings.img-des | image_url }}" width="100%" height="auto" loading="lazy"/>
    <img class="cs_refined_back_mbl_img" src="{{ section.settings.img-mbl | image_url }}" width="100%" height="auto" loading="lazy"/>
    </div>
    <div class="cs_refined_back_content">
    <h3 class="cs_refined_back_title">{{ section.settings.block-title }}</h3>
    <a class="cs_refined_button" href="{{ section.settings.butt-url }}">{{ section.settings.butt-text }}</a>
    </div>
    </div>
</div>
{% schema %}
{
  "name": "Refined Knit Series",
  "settings": [
    {
          "type": "image_picker",
          "id": "img-des",
          "label": "Image Desktop"
        },
         {
          "type": "image_picker",
          "id": "img-mbl",
          "label": "Image Mobile"
        },
        {
          "type": "text",
          "id": "block-title",
          "label": "Heading "
        },
        {
          "type": "text",
          "id": "butt-text",
          "label": "Button Text"
        },
         {
          "type": "url",
          "id": "butt-url",
          "label": "Button Url"
        },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Padding Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
  ],
  "presets": [
    {
      "name": "Refined Knit Series",
      "category": "Custom"
    }
  ]
}
{% endschema %}