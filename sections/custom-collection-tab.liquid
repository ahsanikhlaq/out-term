<script>
document.addEventListener("DOMContentLoaded", () => {
  // Select all sections with the .shop-collections class
  document.querySelectorAll(".shop-collections").forEach((section) => {
    const tabButtons = section.querySelectorAll(".collection-tabs .tab-button");
    const sliders = section.querySelectorAll(".collection-slider");

    tabButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        // Remove 'active' only within this section
        tabButtons.forEach((b) => b.classList.remove("active"));
        sliders.forEach((s) => s.classList.remove("active"));

        btn.classList.add("active");
        const target = btn.dataset.target;
        const targetSlider = section.querySelector(`#${target}`);
        if (targetSlider) targetSlider.classList.add("active");
      });
    });
  });

  // Initialize Swipers for each block
  {% for block in section.blocks %}
    new Swiper(".collection-swiper-{{ block.id }}", {
      slidesPerView: 4,
      spaceBetween: 16,
      speed: 1000,
      pagination: {
        el: ".cs-pagination",
        clickable: true,
      },
      navigation: {
        nextEl: ".cs_coll_tab_sider-button_next",
        prevEl: ".cs_coll_tab_sider-button_prev",
      },
      breakpoints: {
        320: { slidesPerView: 1.2, spaceBetween: 16 },
        768: { slidesPerView: 2.2, spaceBetween: 16 },
        1024: { slidesPerView: 4, spaceBetween: 16 },
      },
    });
  {% endfor %}
});

 document.addEventListener("DOMContentLoaded", function () {
  const tabs = document.querySelectorAll(".tab-button");
  const progressBar = document.querySelector(".tabs-progress-bar");

  const totalTabs = tabs.length;
  const width = 100 / totalTabs;

  // set initial width
  progressBar.style.width = width + "%";

  tabs.forEach((tab, index) => {
    tab.addEventListener("click", function () {
      
      // remove active
      tabs.forEach(t => t.classList.remove("active"));
      tab.classList.add("active");

      // move progress bar
      progressBar.style.transform = `translateX(${index * 100}%)`;
    });
  });
}); 
</script>
