{% comment %}
  Shop the Collections Section
{% endcomment %}
<style>
  #section-{{ section.id }} {
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  background: {{ section.settings.bg_color }};
}
/* Mobile padding */
@media (max-width: 767px) {
  #section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px !important;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
  }
  #section-{{ section.id }} .page-width{
    padding-right: 0;
  }
}
</style>
<section
  class="shop-collections cs-featured-collection"
  id="section-{{ section.id }}"
>
  <div class="page-width">

    <div class="csp-mobs">
    <!-- Heading -->
    <div class="cs_coll_tab_heading_tab_button animate-item">
    <h2 class="live-heading">{{ section.settings.headings }}</h2>

    <!-- Tabs -->
        <div class="collection-tabs animate-item">
          
          <div class="cs_tabs">
            {% for block in section.blocks %}
              <button
                class="tab-button {% if forloop.first %}active{% endif %}"
                data-index="{{ forloop.index0 }}"
                data-target="collection-{{ block.id }}"
              >
                {{ block.settings.collection_name }}
              </button>
            {% endfor %}
          </div>
    </div>
    </div>
    <div class="cs_coll_tab_sider-button animate-item">
        <span class="cs_coll_tab_sider-button_next">{% render 'cs_tab_slider_button' %}</span>
         <span class="cs_coll_tab_sider-button_prev">{% render 'cs_tab_slider_button' %}</span>
    </div>
    </div>

  

    <!-- Collections Wrapper -->
    <div class="collections-wrapper animate-item">
      {% for block in section.blocks %}
        <div
          id="collection-{{ block.id }}"
          class="collection-slider {% if forloop.first %}active{% endif %}"
        >
          <div class="swiper collection-swiper-{{ block.id }} mb-5">
            <div class="swiper-wrapper">
              {% assign selected_collection = collections[block.settings.cs_collection] %}
          {% if selected_collection.products.size > 0 %}
            {% for product in selected_collection.products %}
              <div class="swiper-slide product-card">
                {% render 'custom-product-cart', product: product, section_id: section.id %}
              </div>
            {% endfor %}
          {% endif %}
            </div>

          </div>  
        </div>
      {% endfor %}
    </div>
    <a class="cs_coll_tab_sec_button animate-item" href="{{ section.settings.button-url }}">{{ section.settings.button-text  }}</a>
  </div>
</section>
{% schema %}
{
  "name": "Collections Tab",
  "settings": [
    { "type": "text", "id": "headings", "label": "Section Heading",},
    { "type": "text", "id": "button-text", "label": "Button Text",},
    { "type": "text", "id": "button-url", "label": "Button Url",},
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    { "type": "range", "id": "padding_top_desktop", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Top (Desktop)", "default": 80 },
    { "type": "range", "id": "padding_bottom_desktop", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Bottom (Desktop)", "default": 80 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Top (Mobile)", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Bottom (Mobile)", "default": 40 },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "View Collection"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
       "type":"checkbox",
       "id":"styling",
       "default":false,
       "label": "custom styling"
    }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Collection Tab",
      "settings": [
        { "type": "collection", "id": "cs_collection", "label": "Select Collection" },
        { "type": "text", "id": "collection_name", "label": "Tab Label", "default": "Collection Name" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    { "name": "Collections Tab", "category": "Custom" }
  ]
}
{% endschema %}
