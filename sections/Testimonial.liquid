<style>
  #section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    background: {{ section.settings.bg_color }};
  }

  /* ── Header ── */
  .testi-header-{{ section.id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 36px;
  }
  .testi-heading-{{ section.id }} {
    margin: 0;
    font-family: 'FONTSPRING DEMO - Gibson Book', sans-serif;
    font-weight: 300;
    font-size: 60px;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #221919;
  }

  /* ── Nav buttons ── */
  .testi-nav-{{ section.id }} {
    display: flex;
    flex-direction: row-reverse;
    align-items: center;
    gap: 12px;
  }
  .testi-btn-next-{{ section.id }},
  .testi-btn-prev-{{ section.id }} {
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    padding: 0;
    line-height: 0;
    flex-shrink: 0;
  }
  .testi-btn-next-{{ section.id }} svg rect { fill: #221919; }
  .testi-btn-prev-{{ section.id }} svg rect { fill: transparent; stroke: #22191947; stroke-width: 1; }
  .testi-btn-prev-{{ section.id }} svg path { stroke: #221919; }

  /* ── Swiper wrapper ── */
  .testi-swiper-{{ section.id }} { overflow: hidden; }

  /* ── Card ── */
  .testi-card-{{ section.id }} {
    background: #ffffff;
    border: 1px solid rgba(34, 25, 25, 0.08);
    border-radius: 24px;
    overflow: hidden;
    height: 100%;
  }

  /* ── Card image ── */
  .testi-img-wrap-{{ section.id }} {
    position: relative;
    width: 100%;
    height: 310px;
    overflow: hidden;
  }
  .testi-img-wrap-{{ section.id }} > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Product overlay ── */
  .testi-overlay-{{ section.id }} {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 12px;
    background: #ffffff;
    border-radius: 12px;
    padding: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-sizing: border-box;
  }
  .testi-prod-img-{{ section.id }} img {
    width: 62px;
    height: 62px;
    min-width: 62px;
    min-height: 62px;
    border-radius: 8px;
    object-fit: cover;
    display: block;
  }
  .testi-prod-info-{{ section.id }} {
    flex: 1;
    min-width: 0;
  }
  .testi-prod-name-{{ section.id }} {
    margin: 0 0 3px;
    font-family: Montserrat, sans-serif;
    font-weight: 600;
    font-size: 15px;
    line-height: 1.2;
    text-transform: uppercase;
    color: #221919;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .testi-prod-type-{{ section.id }} {
    margin: 0 0 4px;
    font-family: Montserrat, sans-serif;
    font-weight: 400;
    font-size: 13px;
    line-height: 1.2;
    color: rgba(34, 25, 25, 0.8);
  }
  .testi-prod-price-{{ section.id }} {
    margin: 0;
    font-family: Montserrat, sans-serif;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.2;
    text-transform: uppercase;
    color: #221919;
  }
  /* Quick-add within testimonial overlay — always visible, circular dark icon */
  #section-{{ section.id }} .testi-prod-btn-{{ section.id }} .quick-add {
    position: static;
    inset: unset;
    z-index: unset;
    pointer-events: auto;
  }
  #section-{{ section.id }} .testi-prod-btn-{{ section.id }} .quick-add__product-form-component {
    height: auto;
    display: flex;
    align-items: center;
  }
  #section-{{ section.id }} .testi-prod-btn-{{ section.id }} .quick-add__product-form-component .shopify-product-form {
    height: auto;
    justify-content: center;
    align-items: center;
  }
  #section-{{ section.id }} .testi-prod-btn-{{ section.id }} .quick-add__button {
    position: static !important;
    right: unset !important;
    bottom: unset !important;
    width: 40px !important;
    height: 40px !important;
    min-width: 40px;
    border-radius: 50% !important;
    background: #221919 !important;
    border: none !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    opacity: 1 !important;
    padding: 0 !important;
    backdrop-filter: none !important;
    flex-shrink: 0;
  }
  #section-{{ section.id }} .testi-prod-btn-{{ section.id }} .quick-add__button:hover {
    opacity: 0.75 !important;
    scale: 1;
  }
  #section-{{ section.id }} .testi-prod-btn-{{ section.id }} .quick-add__button .add-to-cart-text__content {
    display: none !important;
  }
  #section-{{ section.id }} .testi-prod-btn-{{ section.id }} .quick-add__button .add-to-cart-icon {
    display: flex !important;
    align-items: center;
    justify-content: center;
    width: 40px !important;
    height: 40px !important;
  }
  #section-{{ section.id }} .testi-prod-btn-{{ section.id }} .quick-add__button svg {
    width: 14px !important;
    height: 14px !important;
    display: block;
  }
  #section-{{ section.id }} .testi-prod-btn-{{ section.id }} .quick-add__button svg path {
    fill: white !important;
  }
  /* Hide the inline "add to bag" text in the choose button */
  #section-{{ section.id }} .testi-prod-btn-{{ section.id }} .cs-add-to-cart-icon_main > span {
    display: none !important;
  }

  /* ── Quick-add popup: brand fonts + full-width button ── */
  #quick-add-dialog .quick-add-modal {
    font-family: Montserrat, sans-serif;
  }
  #quick-add-dialog .view-product-title a,
  #quick-add-dialog .product-header a {
    font-family: 'FONTSPRING DEMO - Gibson Book', sans-serif !important;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0;
  }
  #quick-add-dialog product-price,
  #quick-add-dialog product-price *,
  #quick-add-dialog variant-picker,
  #quick-add-dialog variant-picker * {
    font-family: Montserrat, sans-serif !important;
  }
  #quick-add-dialog .buy-buttons-block button[type="submit"],
  #quick-add-dialog .buy-buttons-block .button {
    width: 100%;
    background: #221919 !important;
    color: #ffffff !important;
    font-family: Montserrat, sans-serif !important;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 0;
    border: none;
  }
  #quick-add-dialog .buy-buttons-block button[type="submit"]:hover,
  #quick-add-dialog .buy-buttons-block .button:hover {
    opacity: 0.85;
  }

  /* ── Card body ── */
  .testi-body-{{ section.id }} {
    padding: 20px;
  }
  .testi-review-{{ section.id }} p {
    margin: 0 0 20px;
    font-family: Montserrat, sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 26px;
    color: #221919;
    min-height: 234px;
  }
  .testi-footer-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4px;
  }
  .testi-name-{{ section.id }} {
    font-family: Montserrat, sans-serif;
    font-weight: 600;
    font-size: 15px;
    line-height: 1.2;
    color: #221919;
  }
  .testi-handle-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: Montserrat, sans-serif;
    font-weight: 400;
    font-size: 13px;
    color: #221919;
    padding: 5px 8px;
    border: 1px solid rgba(34, 25, 25, 0.28);
    line-height: 1;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    #section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }
    .testi-heading-{{ section.id }} { font-size: 36px; }
    .testi-nav-{{ section.id }} { display: none; }
    .testi-header-{{ section.id }} { margin-bottom: 20px; }
    .testi-img-wrap-{{ section.id }} { height: 260px; }
    .testi-review-{{ section.id }} p {
      font-size: 13px;
      line-height: 22px;
      min-height: auto;
    }
    .testi-body-{{ section.id }} { padding: 14px; }
    .testi-prod-type-{{ section.id }},
    .testi-prod-price-{{ section.id }} { display: none; }
    .testi-prod-img-{{ section.id }} img {
      width: 52px;
      height: 52px;
      min-width: 52px;
      min-height: 52px;
    }
  }
</style>

<section id="section-{{ section.id }}">
  <div class="page-width">

    <!-- Header -->
    <div class="testi-header-{{ section.id }}">
      <h2 class="testi-heading-{{ section.id }} animate-item">{{ section.settings.headings }}</h2>
      <div class="testi-nav-{{ section.id }} animate-item">
        <span class="testi-btn-next-{{ section.id }}">
          {% render 'cs_tab_slider_button' %}
        </span>
        <span class="testi-btn-prev-{{ section.id }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="54" height="51" viewBox="0 0 54 51" fill="none">
            <rect width="54" height="51" rx="25.5"/>
            <path d="M40.4872 24.8846H12.7948" stroke="white" stroke-width="0.820514" stroke-linecap="round"/>
            <path d="M25.205 13.5C23.5936 19.3878 18.5677 23.7068 12.5045 24.4142L10.2307 24.6795L12.738 25.3064C18.7917 26.8198 23.5578 31.4814 25.205 37.5" stroke="white" stroke-width="0.820514" stroke-linecap="round"/>
          </svg>
        </span>
      </div>
    </div>

    <!-- Slider -->
    <div class="swiper testi-swiper-{{ section.id }} animate-item">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {%- assign product = all_products[block.settings.cs_product] -%}
          <div class="swiper-slide">
            <div class="testi-card-{{ section.id }}">

              <!-- Image + Overlay -->
              <div class="testi-img-wrap-{{ section.id }}">
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="Customer review photo"
                  width="600"
                  height="310"
                  loading="lazy"
                >
                {%- if product -%}
                  <div class="testi-overlay-{{ section.id }}">
                    <div class="testi-prod-img-{{ section.id }}">
                      <img src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.title }}">
                    </div>
                    <div class="testi-prod-info-{{ section.id }}">
                      <p class="testi-prod-name-{{ section.id }}">{{ product.title | split: ' ' | slice: 0, 2 | join: ' ' }}</p>
                      <p class="testi-prod-type-{{ section.id }}">Classic jersey</p>
                      <p class="testi-prod-price-{{ section.id }}">{{ product.price | money }}</p>
                    </div>
                    <div class="testi-prod-btn-{{ section.id }}">
                      <product-card data-no-navigation style="display:contents">
                        <a href="{{ product.url }}" ref="productCardLink" style="display:none;" aria-hidden="true" tabindex="-1"></a>
                        {% render 'quick-add', product: product, section_id: section.id, block: block %}
                      </product-card>
                    </div>
                  </div>
                {%- endif -%}
              </div>

              <!-- Review body -->
              <div class="testi-body-{{ section.id }}">
                <div class="testi-review-{{ section.id }}">{{ block.settings.rich-text }}</div>
                <div class="testi-footer-{{ section.id }}">
                  <span class="testi-name-{{ section.id }}">{{ block.settings.name }}</span>
                  <span class="testi-handle-{{ section.id }}">{{ block.settings['icon-text'] }} {% render 'cs_testi_icon' %}</span>
                </div>
              </div>

            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Testimonial",
  "settings": [
    { "type": "text", "id": "headings", "label": "Section Heading" },
    { "type": "color", "id": "bg_color", "label": "Background Color" },
    { "type": "range", "id": "padding_top_desktop", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Top (Desktop)", "default": 60 },
    { "type": "range", "id": "padding_bottom_desktop", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Bottom (Desktop)", "default": 60 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Top (Mobile)", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Bottom (Mobile)", "default": 40 }
  ],
  "blocks": [
    {
      "type": "add",
      "name": "Testimonial Card",
      "settings": [
        { "type": "product", "id": "cs_product", "label": "Select Product" },
        { "type": "image_picker", "id": "image", "label": "Customer Photo" },
        { "type": "richtext", "id": "rich-text", "label": "Review Text" },
        { "type": "text", "id": "name", "label": "Reviewer Name" },
        { "type": "text", "id": "icon-text", "label": "Social Handle (e.g. @rayan)" }
      ]
    }
  ],
  "presets": [
    { "name": "Testimonial", "category": "Custom" }
  ]
}
{% endschema %}

<script>
  new Swiper(".testi-swiper-{{ section.id }}", {
    slidesPerView: 4,
    spaceBetween: 16,
    speed: 500,
    navigation: {
      nextEl: ".testi-btn-next-{{ section.id }}",
      prevEl: ".testi-btn-prev-{{ section.id }}",
    },
    breakpoints: {
      320: { slidesPerView: 1.15, spaceBetween: 12 },
      768: { slidesPerView: 2.2, spaceBetween: 16 },
      1024: { slidesPerView: 4, spaceBetween: 16 },
    },
  });
</script>
