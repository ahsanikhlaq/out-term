<section
  class="arr-shop-collections arr-cs-featured-collection"
  id="section-{{ section.id }}"
>
  <div class="page-widths">
  <h4 class="arr_cs_main_heading animate-item">{{ section.settings.headings }}</h4>
    <div class="arr-collections-wrapper animate-item">
      <div class="arr-cs_coll_tab_sider-button arr-cs_coll_tab_sider-button-des">
        <span class="arr-cs_coll_tab_sider-button_next">{% render 'cs_tab_slider_button' %}</span>
        <span class="arr-cs_coll_tab_sider-button_prev">{% render 'cs_tab_slider_button' %}</span>
      </div>

      {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}
        <div
          id="arr-collection-{{ block.id }}"
          class="arr-collection-slider"
        >
          <div class="swiper collection-swiper-{{ block.id }} arr-mb-5 animate-item">
            <div class="swiper-wrapper">
              {% for product in collection.products %}

                <div class="swiper-slide arr-product-card">

                  <a class="arr-dps-image" href="{{ product.url }}">
                    <img
                      src="{{ product.featured_image | img_url: '480x480' }}"
                      alt="{{ product.title }}"
                    >
                    <div class="arr-cs_coll_tab_pro_size_varint">
  {% assign size_option_index = nil %}
  {% assign first_available_found = false %}

  {% for option in product.options %}
    {% if option == 'Size' %}
      {% assign size_option_index = forloop.index0 %}
    {% endif %}
  {% endfor %}

  {% if size_option_index != nil %}
    {% for variant in product.variants %}
      
      {% assign is_checked = false %}
      {% if variant.available and first_available_found == false %}
        {% assign is_checked = true %}
        {% assign first_available_found = true %}
      {% endif %}

      <span class="arr-size-badge {% unless variant.available %}out-of-stock{% endunless %}">
        
        <input 
          class="arr-size-badge_input" 
          type="radio"
          name="variant-size-{{ product.id }}"
          value="{{ variant.id }}"
          {% if is_checked %}checked{% endif %}
          {% unless variant.available %}disabled{% endunless %}
        >

        <label>
          {{ variant.options[size_option_index] }}
        </label>

      </span>

    {% endfor %}
  {% endif %}
</div>
                  </a>

                  <div class="arr-cs_coll_tab_cart_content">
                  
                    <div class="arr-cs_coll_tab_title_varint">
                      <h4 class="arr-dps-title">{{ product.title }}</h4>
                    </div>

                    <span class="arr-cs_coll_tab_pro_price">{{ product.price | money }}</span>

                    <div class="arr-cs_coll_tab_pro_color_varint">
                      {% assign color_option = nil %}
                      {% for option in product.options_with_values %}
                        {% if option.name == 'Color' %}
                          {% assign color_option = option %}
                        {% endif %}
                      {% endfor %}

                      {% if color_option != nil %}
                        <div class="arr-color-swatches">
                          {% for option_value in color_option.values %}

                            {% assign swatch_value = '#cccccc' %}
                            {% if option_value.swatch.color %}
                              {% assign swatch_value = 'rgb(' | append: option_value.swatch.color.rgb | append: ')' %}
                            {% elsif option_value.swatch.image %}
                              {% assign swatch_img = option_value.swatch.image | image_url: width: 80 %}
                              {% assign swatch_value = 'url(' | append: swatch_img | append: ')' %}
                            {% endif %}

                            <label class="arr-color-badge">
                              <input class="arr-color-badge_input" type="radio"
                                name="variant-color-{{ product.id }}"
                                value="{{ option_value.name }}"
                                {% if forloop.first %}checked{% endif %}>
                              <span class="arr-color-circle" style="background: {{ swatch_value }};"></span>
                            </label>

                          {% endfor %}
                        </div>
                      {% endif %}
                    </div> 

                    <button 
  class="arr-cs_coll_tab_cart_buy_button"
  {% unless product.available %} disabled {% endunless %}
>
  <input class="arr-cs_coll_tab_slect_size" type="hidden" name="slected-size" value="">
  <input class="arr-cs_coll_tab_slect_color" type="hidden" name="slected-color" value="">
  {% render 'buy-button-bag-svg' %}
  {% if product.available %}
    add to bag
  {% else %}
    out of stock
  {% endif %}
</button>
                  </div>

                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="arr-cs_coll_tab_sider-button arr-cs_coll_tab_sider-button-mbl animate-item">
        <span class="arr-cs_coll_tab_sider-button_next">{% render 'cs_tab_slider_button' %}</span>
        <span class="arr-cs_coll_tab_sider-button_prev">{% render 'cs_tab_slider_button' %}</span>
      </div>
  </div>
</section>
{% schema %}
{
  "name": "new arrivals",
  "settings": [
    { "type": "text", "id": "headings", "label": "Section Heading",},
     {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    { "type": "range", "id": "padding_top_desktop", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Top (Desktop)", "default": 80 },
    { "type": "range", "id": "padding_bottom_desktop", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Bottom (Desktop)", "default": 80 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Top (Mobile)", "default": 40 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding Bottom (Mobile)", "default": 40 },
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Collection Tab",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Select Collection" },
        { "type": "text", "id": "collection_name", "label": "Tab Label", "default": "Collection Name" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    { "name": "new arrivals", "category": "Custom" }
  ]
}
{% endschema %}
{% comment %} ---tab-script {% endcomment %}
 <script>
  // Initialize Swipers for each block
  {% for block in section.blocks %}
    new Swiper(".collection-swiper-{{ block.id }}", {
      slidesPerView: 2.3,
      spaceBetween: 20,
       centeredSlides: true,
      speed: 1000,
      loop: true,
      pagination: {
        el: ".arr-cs-pagination",
        clickable: true,
      },
      navigation: {
        nextEl: ".arr-cs_coll_tab_sider-button_next",
        prevEl: ".arr-cs_coll_tab_sider-button_prev",
      },
      breakpoints: {
        320: { slidesPerView: 1.2, spaceBetween: 16 },
        768: { slidesPerView: 2.2, spaceBetween: 16 },
        1024: { slidesPerView: 2.3, spaceBetween: 20   },
      },
    });
  {% endfor %}
</script>
{% comment %} ------------------add-to-cart----------------- {% endcomment %}
<script>
document.addEventListener('DOMContentLoaded', function () {

  // 1. Helper: Sync size + color
  function syncHiddenInputs(card) {
    const sizeInput = card.querySelector('.arr-size-badge_input:checked');
    const colorInput = card.querySelector('.arr-color-badge_input:checked');
    const hiddenSize = card.querySelector('.arr-cs_coll_tab_slect_size');
    const hiddenColor = card.querySelector('.arr-cs_coll_tab_slect_color');
    if (hiddenSize) hiddenSize.value = sizeInput ? sizeInput.value : '';
    if (hiddenColor) hiddenColor.value = colorInput ? colorInput.getAttribute('variant-id') : '';
  }

  document.querySelectorAll('.swiper-slide.arr-product-card').forEach(card => syncHiddenInputs(card));

  // 2. Selection changes
  document.querySelectorAll('.arr-size-badge_input, .arr-color-badge_input').forEach(input => {
    input.addEventListener('change', function () {
      const card = this.closest('.swiper-slide.arr-product-card');
      if (card) {
        if (this.classList.contains('arr-color-badge_input')) {
          const colorNameSpan = card.querySelector('.arr-selected-color-name');
          if (colorNameSpan) colorNameSpan.textContent = this.value;
        }
        syncHiddenInputs(card);
      }
    });
  });

  // 3. Correct section ID nikalo page se
  function getCartSectionId() {
    const cartItems = document.querySelector('cart-items-component[data-section-id]');
    if (cartItems) return cartItems.getAttribute('data-section-id');
    return 'sections--26355253805372__header_section'; // fallback
  }

  // 4. Add to Cart Logic
  document.querySelectorAll('.arr-cs_coll_tab_cart_buy_button').forEach(button => {
    button.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopImmediatePropagation();

      const btn = this;
      const card = btn.closest('.swiper-slide.arr-product-card');
      if (!card) return;

      const variantId = card.querySelector('.arr-cs_coll_tab_slect_size')?.value ||
                        card.querySelector('.arr-cs_coll_tab_slect_color')?.value;

      if (!variantId) {
        alert('Please select options first!');
        return;
      }

      btn.disabled = true;
      const originalHTML = btn.innerHTML;
      btn.innerHTML = 'Adding...';

      const sectionId = getCartSectionId();

      const formData = {
        id: variantId,
        quantity: 1,
        sections: sectionId
      };

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      })
      .then(response => response.json())
      .then(parsedState => {
        if (parsedState.status === 422) throw new Error(parsedState.description);

        const cartDrawer = document.querySelector('cart-drawer-component');
        const sectionHTML = parsedState.sections?.[sectionId];

        if (cartDrawer && sectionHTML) {
          const parsed = new DOMParser().parseFromString(sectionHTML, 'text/html');

          // cart-items-component update karo
          const newCartItems = parsed.querySelector('cart-items-component');
          const currentCartItems = cartDrawer.querySelector('cart-items-component');

          if (currentCartItems && newCartItems) {
            currentCartItems.innerHTML = newCartItems.innerHTML;
          } else {
            const newInner = parsed.querySelector('[data-hydration-key="cart-drawer-inner"]') ||
                             parsed.querySelector('arr-.cart-drawer__inner');
            const currentInner = cartDrawer.querySelector('[data-hydration-key="cart-drawer-inner"]') ||
                                 cartDrawer.querySelector('arr-.cart-drawer__inner');
            if (currentInner && newInner) {
              currentInner.innerHTML = newInner.innerHTML;
            }
          }

          // Empty class hata do
          const dialog = cartDrawer.querySelector('dialog');
          if (dialog) {
            dialog.classList.remove('cart-drawer--empty');
          }
        }

        // Cart bubble update
        const cartBubbleCount = document.querySelector('[ref="cartBubbleCount"], .arr-cart-bubble__text-count');
        if (cartBubbleCount && parsedState.items_count !== undefined) {
          cartBubbleCount.textContent = parsedState.items_count;
          cartBubbleCount.classList.remove('hidden');
          const bubble = document.querySelector('[ref="cartBubble"], .arr-cart-bubble');
          if (bubble) bubble.classList.remove('visually-hidden');
        }

        // 5. Drawer open karo
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const drawerEl = document.querySelector('cart-drawer-component');
            if (drawerEl) {

              // Pehle theme ka trigger button try karo
              const cartTriggerBtn = drawerEl.querySelector('[data-testid="cart-drawer-trigger"], [on\\:click="/open"]');
              if (cartTriggerBtn) {
                cartTriggerBtn.click();
              } else {
                // Fallback: dialog force open
                const dialog = drawerEl.querySelector('dialog[ref="dialog"]');
                if (dialog) {
                  dialog.setAttribute('open', '');
                  dialog.style.display = 'flex';
                  dialog.style.visibility = 'visible';
                  dialog.style.opacity = '1';
                  dialog.style.transform = 'translateX(0)';
                }
                document.body.classList.add('overflow-hidden');
              }
            }

            document.dispatchEvent(new CustomEvent('cart:updated', {
              detail: { cart: parsedState }
            }));
          });
        });

      })
      .catch(error => {
        console.error('Cart Error:', error);
        alert(error.message || 'Kuch masla hua, dobara try karo.');
      })
      .finally(() => {
        btn.disabled = false;
        btn.innerHTML = originalHTML;
      });

    });
  });

});
</script>







<script>
document.addEventListener("change", function() {
  const variantAvailable = document.querySelector('[name="id"] option:checked')?.dataset.available;

  const btn = document.querySelector('.arr-cs_coll_tab_cart_buy_button');

  if (variantAvailable === "false") {
    btn.disabled = true;
    btn.innerText = "Out of Stock";
  } else {
    btn.disabled = false;
    btn.innerText = "Add to Bag";
  }
});</script>