{% comment %}
  Our Visions Section - Shopify Liquid
  Desktop: 3-column asymmetric layout with overlapping images
  Mobile: Stacked single-column layout
{% endcomment %}

<section
  class="our-visions"
  id="section-{{ section.id }}"
>
<div class="page-width">
  {%- if section.settings.show_founded_banner -%}
  <div class="our-visions__banner animate-item">
    <p>
      <strong>{{ section.settings.founded_bold_text }}</strong>
      {{ section.settings.founded_text }}
    </p>
  </div>
  {%- endif -%}

  <div class="our-visions__grid animate-item">

    {%- comment -%} LEFT COLUMN — Image 1 + Heading + Body {%- endcomment -%}
    <div class="our-visions__col our-visions__col--left animate-item">

      {%- if section.settings.image_1 != blank -%}
        <div class="our-visions__img-wrap our-visions__img-wrap--1 animate-item">
          {{
            section.settings.image_1
            | image_url: width: 560
            | image_tag:
              loading: 'lazy',
              alt: section.settings.image_1.alt | default: 'Vision image 1',
              class: 'our-visions__img'
          }}
        </div>
      {%- else -%}
        <div class=" animate-item our-visions__img-wrap our-visions__img-wrap--1 our-visions__img-placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'our-visions__img' }}
        </div>
      {%- endif -%}

      <div class="animate-item our-visions__text-block">
        {%- if section.settings.heading != blank -%}
          <h2 class="animate-item our-visions__heading" style="color: {{ section.settings.heading_color }};">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.subtext != blank -%}
          <p class="animate-item our-visions__subtext" style="color: {{ section.settings.text_color }};">
            {{ section.settings.subtext }}
          </p>
        {%- endif -%}
      </div>

    </div>

    {%- comment -%} MIDDLE COLUMN — Image 2 {%- endcomment -%}
    <div class="our-visions__col our-visions__col--middle">
      {%- if section.settings.image_2 != blank -%}
        <div class="animate-item our-visions__img-wrap our-visions__img-wrap--2">
          {{
            section.settings.image_2
            | image_url: width: 420
            | image_tag:
              loading: 'lazy',
              alt: section.settings.image_2.alt | default: 'Vision image 2',
              class: 'our-visions__img'
          }}
        </div>
      {%- else -%}
        <div class="animate-item our-visions__img-wrap our-visions__img-wrap--2 our-visions__img-placeholder">
          {{ 'lifestyle-2' | placeholder_svg_tag: 'our-visions__img' }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} RIGHT COLUMN — Image 3 + Description {%- endcomment -%}
    <div class="animate-item our-visions__col our-visions__col--right">

      {%- if section.settings.image_3 != blank -%}
        <div class="animate-item our-visions__img-wrap our-visions__img-wrap--3">
          {{
            section.settings.image_3
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              alt: section.settings.image_3.alt | default: 'Vision image 3',
              class: 'our-visions__img'
          }}
        </div>
      {%- else -%}
        <div class="animate-item our-visions__img-wrap our-visions__img-wrap--3 our-visions__img-placeholder">
          {{ 'lifestyle-3' | placeholder_svg_tag: 'our-visions__img' }}
        </div>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="animate-item our-visions__description" style="color: {{ section.settings.text_color }};">
          {{ section.settings.description }}

          {%- if section.settings.show_read_more and section.settings.read_more_link != blank -%}
            <a
              href="{{ section.settings.read_more_link }}"
              class="animate-item our-visions__read-more"
              style="color: {{ section.settings.heading_color }};"
            >
              {{ section.settings.read_more_label | default: 'READ MORE' }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>

  </div>
</div>
</section>

<style>
  #section-{{ section.id }} {
     background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  /* ─── FOUNDED BANNER ─── */
  #section-{{ section.id }} .our-visions__banner {
    max-width: 1100px;
    margin: 0 auto {{ section.settings.banner_margin_bottom }}px;
    padding: 18px 28px;
    background: #fff;
  }
  #section-{{ section.id }} .our-visions__banner p{
   font-family: Montserrat;
    font-weight: 300;
    font-style: SemiBold;
    font-size: 18px;
    leading-trim: NONE;
    line-height: 26px;
    letter-spacing: 0;
    text-align: center;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
  }

  #section-{{ section.id }} .our-visions__banner strong {
    font-weight: 600;
    color: {{ section.settings.heading_color }};
  }

  /* ─── GRID LAYOUT ─── */
  #section-{{ section.id }} .our-visions__grid {
    display: grid;
    grid-template-columns: auto 45%;
    gap: 0;
    align-items: start;
    margin: 0 auto;
    padding: 0 20px;
        position: relative;
  }
.our-visions__col--middle img{
    max-width: 310px;
    max-height: 452px;
    display: block;
    object-fit: cover;
}
.our-visions__col--middle{
    position: absolute;
    bottom: 41px;
    left: 45%;
    transform: translateX(-50%);
    z-index: 0;
}
.our-visions__col--left img{
display: block;
    max-width: 450px;
    max-height: 667px;
    object-fit: cover;
}
  /* ─── COLUMNS ─── */
  

  #section-{{ section.id }} .our-visions__col--left {
    padding-right: 24px;
  }

  #section-{{ section.id }} .our-visions__col--right {
    padding-left: 40px;
  }

  /* ─── IMAGES ─── */
  #section-{{ section.id }} .our-visions__img-wrap {
    width: 100%;
    overflow: hidden;
  }

  #section-{{ section.id }} .our-visions__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  {% comment %} #section-{{ section.id }} .our-visions__img-wrap--1 { aspect-ratio: 3/4; }
  #section-{{ section.id }} .our-visions__img-wrap--2 { aspect-ratio: 3/4; }
  #section-{{ section.id }} .our-visions__img-wrap--3 { aspect-ratio: 4/5; } {% endcomment %}

  #section-{{ section.id }} .our-visions__img-placeholder svg {
    width: 100%;
    height: 100%;
    background: #e8e8e8;
  }

  /* ─── TEXT BLOCK (LEFT COLUMN) ─── */
  #section-{{ section.id }} .our-visions__text-block {
    margin-top: 19px;
        position: relative;
    z-index: 1;
    max-width: 436px;
  }
.our-visions__col--right img{
max-width: 500px;
    max-height: 645px;
    margin-left: auto;
    display: block;
    object-fit: cover;
}
  #section-{{ section.id }} .our-visions__heading {
   font-family: 'FONTSPRING DEMO - Gibson Book';
    font-weight: 300;
    font-style: Regular;
    font-size: 70px;
    leading-trim: NONE;
    line-height: 73px;
    letter-spacing: 0%;
    vertical-align: middle;
    text-transform: uppercase;
    margin: 0;
    color: #221919; 
    max-width: 300px;
  }

  #section-{{ section.id }} .our-visions__subtext {
    font-family: Montserrat;
        font-weight: 400;
        font-style: Regular;
        font-size: 14px;
        leading-trim: NONE;
        line-height: 28px;
        letter-spacing: 11%;
        text-transform: uppercase;
        color: #221919;
  }

  /* ─── DESCRIPTION (RIGHT COLUMN) ─── */
  #section-{{ section.id }} .our-visions__description p{
    margin-top: 28px;
   font-family: Montserrat;
        font-weight: 400;
        font-style: Regular;
        font-size: 14px;
        leading-trim: NONE;
        line-height: 28px;
        letter-spacing: 11%;
        text-transform: uppercase;
        color: #221919;
        text-align: right;
  }

  #section-{{ section.id }} .our-visions__read-more {
    display: block;
    margin-top: 20px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: underline;
    text-align: left;
    text-underline-offset: 3px;
  }

  #section-{{ section.id }} .our-visions__read-more:hover {
    opacity: 0.65;
  }

  /* ─── MOBILE ─── */
  @media (max-width: 767px) {
    #section-{{ section.id }} .our-visions__grid {
      grid-template-columns: 1fr;
              padding: 0;
        gap: 25px;
    }
    #section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mbl }}px;
    padding-bottom: {{ section.settings.padding_bottom_mbl }}px;
  }

    #section-{{ section.id }} .our-visions__col--left,
    #section-{{ section.id }} .our-visions__col--middle,
    #section-{{ section.id }} .our-visions__col--right {
      padding: 0;
    }

    #section-{{ section.id }} .our-visions__img-wrap--2 {
      width: 100%;
    }

    #section-{{ section.id }} .our-visions__description {
      text-align: left;
    }

    #section-{{ section.id }} .our-visions__subtext {
      max-width: 100%;
    }

    #section-{{ section.id }} .our-visions__banner {
      margin-bottom: 24px;
      font-size: 10px;
      padding: 14px 18px;
    }
    {% comment %} -- {% endcomment %}
     .our-visions__col--left img {
    max-width: 100%;
    max-height: 100%;
    object-fit: cover;
}
#section-{{ section.id }} .our-visions__heading {
    font-size: 40px;
    line-height: 40px;
  }
 .our-visions__col--middle img {
    max-width: 175px;
    max-height: 214px;
}
.our-visions__col--middle{
right: -12px;
    transform: unset;
    top: 15.5%;
    left: unset;
}
 #section-{{ section.id }} .our-visions__description p{
    margin-top: 23px;
        text-align: left;
  }
  }
  #section-{{ section.id }} .our-visions__banner p{
    font-size: 15px;
    line-height: 24px;
  }

</style>

{% schema %}
{
  "name": "Our Visions",
  "tag": "section",
  "class": "section-our-visions",
  "settings": [
    {
      "type": "header",
      "content": "── Layout & Container ──"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
     {
      "type": "range",
      "id": "padding_top_mbl",
      "label": "Mobile Padding Top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mbl",
      "label": "Mobile Padding Bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "header",
      "content": "── Colors ──"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f0efed"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "── Typography ──"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font Family",
      "options": [
        { "value": "Helvetica Neue", "label": "Helvetica Neue" },
        { "value": "Georgia", "label": "Georgia" },
        { "value": "Futura", "label": "Futura" },
        { "value": "Garamond", "label": "Garamond" },
        { "value": "Courier New", "label": "Courier New" }
      ],
      "default": "Helvetica Neue"
    },
    {
      "type": "header",
      "content": "── Founded Banner ──"
    },
    {
      "type": "checkbox",
      "id": "show_founded_banner",
      "label": "Show Founded Banner",
      "default": true
    },
    {
      "type": "text",
      "id": "founded_bold_text",
      "label": "Bold Prefix Text",
      "default": "Founded in 2021,"
    },
    {
      "type": "textarea",
      "id": "founded_text",
      "label": "Banner Body Text",
      "default": "Our terms started with a vision: to make casualwear exciting, accessible, and empowering. Today, OT has grown into a community of like-minded individuals who value authenticity, comfort, and bold self-expression."
    },
    {
      "type": "range",
      "id": "banner_margin_bottom",
      "label": "Banner Bottom Margin (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48
    },
    {
      "type": "header",
      "content": "── Images ──"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 (Left – Portrait)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (Middle – Overlapping)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 (Right – Large)"
    },
    {
      "type": "header",
      "content": "── Text Content ──"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Our\nVisions"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext (below heading)",
      "default": "We started our terms to create something that's truly ours — not shaped by trends, but by what we believe works best for real, everyday lifestyles."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Right Column Description",
      "default": "<p>Our pieces are made to be lived in — styled, worn, and vibed with all day, every day. On your terms. Because it's never been about trends. It's about you. Your personality, your energy, your self-expression. If something feels right, wear it — no permission needed.</p>"
    },
    {
      "type": "header",
      "content": "── Read More Button ──"
    },
    {
      "type": "checkbox",
      "id": "show_read_more",
      "label": "Show Read More Link",
      "default": true
    },
    {
      "type": "text",
      "id": "read_more_label",
      "label": "Read More Label",
      "default": "Read More"
    },
    {
      "type": "url",
      "id": "read_more_link",
      "label": "Read More URL"
    }
  ],
  "presets": [
    {
      "name": "Our Visions"
    }
  ]
}
{% endschema %}
